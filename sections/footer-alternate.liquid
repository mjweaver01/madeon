{%- comment -%}
================================================================================
sections/footer-alternate.liquid
Alternate brand footer for Bullet Theme 6.0.0
================================================================================
{%- endcomment -%}

{%- style -%}
/* Alternate Brand Footer Color Overrides */
#footerAlternate {
    --bg: {{ section.settings.footer_bg_color }};
    --bgRGB: {{ section.settings.footer_bg_color | color_extract: 'red' }}, {{ section.settings.footer_bg_color | color_extract: 'green' }}, {{ section.settings.footer_bg_color | color_extract: 'blue' }};
    --color: {{ section.settings.footer_text_color }};
    --colorRGB: {{ section.settings.footer_text_color | color_extract: 'red' }}, {{ section.settings.footer_text_color | color_extract: 'green' }}, {{ section.settings.footer_text_color | color_extract: 'blue' }};
    --globalBorder: {{ section.settings.footer_border_color }};
    background-color: var(--bg);
    color: var(--color);
}

#footerAlternate a {
    color: {{ section.settings.footer_link_color }};
}

#footerAlternate a:hover {
    color: {{ section.settings.footer_link_hover }};
}

#footerAlternate h1,
#footerAlternate h2,
#footerAlternate h3,
#footerAlternate h4,
#footerAlternate h5,
#footerAlternate h6,
#footerAlternate .h1,
#footerAlternate .h2,
#footerAlternate .h3,
#footerAlternate .h4,
#footerAlternate .h5,
#footerAlternate .h6 {
    color: {{ section.settings.footer_heading_color }};
}

#footerAlternate .text-bold,
#footerAlternate strong {
    color: {{ section.settings.footer_heading_color }};
}

/* Newsletter styling */
#footerAlternate #f-newsletter input[type="email"] {
    background-color: {{ section.settings.newsletter_input_bg }};
    color: {{ section.settings.newsletter_input_text }};
    border-color: {{ section.settings.footer_border_color }};
      width: 100%;
    margin-bottom: 5px;
}

#footerAlternate #f-newsletter input[type="email"]::placeholder {
    color: {{ section.settings.newsletter_input_text }};
    opacity: 0.6;
}

#footerAlternate #f-newsletter button,
#footerAlternate #f-newsletter input[type="submit"] {
    background-color: {{ section.settings.newsletter_button_bg }};
    color: {{ section.settings.newsletter_button_text }};
}

#footerAlternate #f-newsletter button:hover,
#footerAlternate #f-newsletter input[type="submit"]:hover {
    opacity: 0.9;
}

/* Social icons */
#footerAlternate .foosocial a {
    color: {{ section.settings.footer_link_color }};
}

#footerAlternate .foosocial a:hover {
    color: {{ section.settings.footer_link_hover }};
}

{%- endstyle -%}

<footer id="footerAlternate" class="footer-alternate" data-brand="{{ section.settings.brand_name | handleize }}">
    <x-flex direction-s="column" wrap="wrap">
        {%- for block in section.blocks -%}
            {%- case block.type -%}
                {%- when 'liquid' -%}
                    <x-cell id="f-liquid-{{ block.id }}" class="hasb" data-fullwidth="{{ block.settings.fullwidth }}" {{ block.shopify_attributes }}>
                        <div class="rte">{{ block.settings.liquid }}</div>
                    </x-cell>

                {%- when 'image' -%}
                    <x-cell id="f-image" class="hasb" data-fullwidth="{{ block.settings.fullwidth }}" {{ block.shopify_attributes }}>
                        <x-flex ai="center" {{ block.settings.alignment | replace: 'left', 'start' | replace: 'right', 'end' | prepend: 'jc="' | append: '"' }} class="image" style="--_imgSize:{% if block.settings.image_fullwidth %}100%{% else %}{{ block.settings.size | append: 'px' }}{% endif %};">
                            {%- liquid 
                                assign img = block.settings.image
                                assign width = block.settings.size
                                render 'inc-img' img: img, loading: 'lazy', fetchpriority: 'low', fallback: true, width: width
                            -%}
                        </x-flex>
                    </x-cell>

                {%- when 'motto' -%}
                    <x-cell id="f-motto" class="hasb" data-fullwidth="{{ block.settings.fullwidth }}" {{ block.shopify_attributes }}>
                        <div class="mpti rte">{{ block.settings.motto }}</div>
                    </x-cell>

                {%- when 'newsletter' -%}
                    <x-cell id="f-newsletter" class="hasb" data-fullwidth="{{ block.settings.fullwidth }}" {{ block.shopify_attributes }}>
                        <x-flex direction="column">
                            <x-cell>
                                <p>{{ block.settings.footerNewsletterTitle }}</p>
                            </x-cell>
                            <x-cell>
                                {%- comment -%} Custom newsletter form with brand tagging {%- endcomment -%}
                                {%- form 'customer', id: 'footer-newsletter-alternate', class: 'footer-newsletter' -%}
                                    <input type="hidden" name="contact[tags]" value="newsletter,{{ section.settings.brand_name | handleize }}">
                                    <div class="newsletter-form">
                                        <input 
                                            type="email" 
                                            name="contact[email]" 
                                            placeholder="{{ 'newsletter.EmailPlaceholder' | t }}"
                                            required
                                            autocomplete="email"
                                        >
                                        <button type="submit">{{ 'newsletter.subscribe' | t }}</button>
                                    </div>
                                {%- endform -%}
                            </x-cell>
                        </x-flex>
                    </x-cell>

                {%- when 'menu' -%}
                    <x-cell
                        id="f-links"
                        class="hasb"
                        data-fullwidth="{{ block.settings.fullwidth }}"
                        data-multicolumn="{{ block.settings.multicolumn }}"
                        data-nested="{{ block.settings.show_nested }}"
                        {{ block.shopify_attributes }}
                    >
                       <x-flex class="f-links" jc="{{ block.settings.alignment_desktop | replace: 'left', 'start' | replace: 'right', 'end' }}" jc-s="{{ block.settings.alignment_mobile | replace: 'left', 'start' | replace: 'right', 'end' }}">
                                {%- liquid
                                    assign menu_links = linklists[block.settings.menu].links
                                    assign show_nested = false
                                    assign columns = 1
                                    assign has_top_level_links = false
                                    assign has_nested_items = false
                                    assign element = 'x-flex'

                                    if block.settings.multicolumn == true
                                        assign element = 'x-grid'

                                        if block.settings.show_nested == true
                                            assign columns = 0
                                            for link in menu_links
                                                if link.links.size > 0
                                                    assign has_nested_items = true
                                                    assign columns = columns | plus: 1
                                                else
                                                    assign has_top_level_links = true
                                                endif
                                            endfor

                                            if has_nested_items == true
                                                assign show_nested = true
                                                if has_top_level_links == true
                                                    assign columns = columns | plus: 1
                                                endif
                                                if columns > 4
                                                    assign columns = 4
                                                endif
                                            else
                                                assign total_links = menu_links.size
                                                if total_links <= 5
                                                    assign columns = 1
                                                else
                                                    assign columns = total_links | divided_by: 3 | plus: 1
                                                endif
                                                if columns > 4
                                                    assign columns = 4
                                                endif
                                            endif
                                        else
                                            assign total_links = menu_links.size
                                            if total_links <= 5
                                                assign columns = 1
                                            else
                                                assign columns = total_links | divided_by: 3 | plus: 1
                                            endif
                                            if columns > 4
                                                assign columns = 4
                                            endif
                                        endif
                                    endif
                                -%}

                                {%- if show_nested == true -%}
                                    <x-grid columns="{{ columns }}" columns-s="2">
                                        {%- for link in menu_links -%}
                                            {%- if link.links.size > 0 -%}
                                                <x-cell>
                                                    <h3 class="h6"><a href="{{ link.url }}" class="no-style text-bold">{{ link.title }}</a></h3>
                                                    <ul class="no-style">
                                                        {%- for child_link in link.links -%}
                                                            <li>
                                                                <a href="{{ child_link.url }}" class="no-style">{{ child_link.title }}</a>
                                                            </li>
                                                        {%- endfor -%}
                                                    </ul>
                                                </x-cell>
                                            {%- endif -%}
                                        {%- endfor -%}

                                        {%- if has_top_level_links == true -%}
                                            <x-cell>
                                                <ul class="no-style">
                                                    {%- for link in menu_links -%}
                                                        {%- if link.links.size == 0 -%}
                                                            <li>
                                                                <a href="{{ link.url }}" class="no-style">{{ link.title }}</a>
                                                            </li>
                                                        {%- endif -%}
                                                    {%- endfor -%}
                                                </ul>
                                            </x-cell>
                                        {%- endif -%}
                                    </x-grid>

                                {%- else -%}
                                    <{{ element }} wrap="wrap" columns="{{ columns }}" columns-s="2">
                                        {%- for link in menu_links -%}
                                            <x-cell>
                                                <a href="{{ link.url }}" class="no-style">{{ link.title }}</a>
                                            </x-cell>
                                        {%- endfor -%}
                                    </{{ element }}>
                                {%- endif -%}
                        </x-flex>
                    </x-cell>

                {%- when 'legalLinks' -%}
                    <x-cell
                            id="f-links"
                            class="hasb"
                            data-fullwidth="{{ block.settings.fullwidth }}"
                            data-multicolumn="{{ block.settings.multicolumn }}"
                            {{ block.shopify_attributes }}
                        >
                        <x-flex class="f-links" jc="{{ block.settings.alignment_desktop | replace: 'left', 'start' | replace: 'right', 'end' }}" jc-s="{{ block.settings.alignment_mobile | replace: 'left', 'start' | replace: 'right', 'end' }}">
                            <x-cell>
                            <ul class="no-style">
                                {%- if block.settings.legalMenu != null -%}
                                    {%- assign linklist = block.settings.legalMenu -%}
                                    {%- for link in linklists[linklist].links -%}
                                        <li><a href="{{ link.url }}" class="no-style">{{ link.title }}</a></li>
                                    {%- endfor -%}
                                {%- else -%}
                                    {%- for policy in shop.policies -%}
                                    {%- if policy != blank -%}
                                        <li><a href="{{ policy.url }}" class="no-style">{{ policy.title }}</a></li>
                                    {%- endif -%}
                                    {%- endfor -%}
                                {%- endif -%}
                            </ul>
                            </x-cell>
                        </x-flex>
                    </x-cell>

                {%- when 'socials' -%}
                    {%- capture social_items -%}{%- render 'global-social' -%}{%- endcapture -%}
                    {%- assign social_items = social_items | strip -%}
                    {%- assign has_follow_on_shop = false -%}
                    {%- if shop.features.follow_on_shop? and block.settings.enable_follow_on_shop -%}
                        {%- assign has_follow_on_shop = true -%}
                    {%- endif -%}
                    {%- if social_items != blank or has_follow_on_shop -%}
                    <x-cell id="f-socials" class="ssocialss" data-fullwidth="{{ block.settings.fullwidth }}" {{ block.shopify_attributes }}>
                        <ul
                            class="foosocial mob-scroll no-style{% if settings.iconsTrue == true %} iconstrue{% endif %}"
                            jc="{{ block.settings.alignment_desktop | replace: 'left', 'start' | replace: 'right', 'end' }}"
                            jc-s="{{ block.settings.alignment_mobile | replace: 'left', 'start' | replace: 'right', 'end' }}"
                        >
                            {{ social_items }}

                            {%- if has_follow_on_shop -%}
                                <li class="follow-on-shop">{{ shop | login_button: action: 'follow' }}</li>
                            {%- endif -%}
                        </ul>
                    </x-cell>
                    {%- endif -%}

                {%- when 'copyright' -%}
                    <x-cell id="f-copyright" class="hasb" data-fullwidth="{{ block.settings.fullwidth }}" {{ block.shopify_attributes }}>
                        <x-flex jc="{{ block.settings.alignment_desktop | replace: 'left', 'start' | replace: 'right', 'end' }}" jc-s="{{ block.settings.alignment_mobile | replace: 'left', 'start' | replace: 'right', 'end' }}">
                            <p class="copyright">
                                &copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name | default: shop.name }}. {{ block.settings.copyright_text }}
                            </p>
                        </x-flex>
                    </x-cell>

            {%- endcase -%}
        {%- endfor -%}
    </x-flex>
</footer>
 
